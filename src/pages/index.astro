---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'

const posts = await getCollection('posts', ({ data }) => !data.draft)
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
---

<BaseLayout title="Blog" description="Latest news and updates from the AcreetionOS operating system project. Maintained by Natalie Spiva.">
  <div class="content-box" style="margin-bottom: 2rem;">
    <div class="box-header">
      <h2><i class="bi bi-newspaper" style="margin-right: 0.5rem;"></i>AcreetionOS Blog</h2>
    </div>
    <div class="box-body">
      <p style="margin: 0;">
        Updates, development progress, and community news from the project.
        <a href="/rss.xml"><i class="bi bi-rss"></i> RSS</a>
      </p>
    </div>
  </div>

  {posts.length === 0 && (
    <div class="content-box">
      <div class="box-body" style="text-align: center; padding: 3rem;">
        <p style="margin: 0; color: var(--acreetion-text);">
          <i class="bi bi-inbox" style="font-size: 2rem; display: block; margin-bottom: 1rem;"></i>
          No posts yet. Coming soon.
        </p>
      </div>
    </div>
  )}

  <ul class="post-list">
    {posts.map((post) => (
      <li class="post-card">
        <a href={`/posts/${post.id}`} class="post-card-title">
          {post.data.title}
        </a>
        <div class="meta" style="margin-top: 0.4rem;">
          <i class="bi bi-calendar3" style="font-size: 0.75rem;"></i>
          {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          {post.data.tags?.map(tag => <span class="tag">{tag}</span>)}
        </div>
        <p style="margin: 0.4rem 0 0; font-size: 0.9rem;">
          {post.data.description}
        </p>
      </li>
    ))}
  </ul>
</BaseLayout>
