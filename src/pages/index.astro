---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'

const posts = await getCollection('posts', ({ data }) => !data.draft)
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
---

<BaseLayout title="Blog" description="Latest news and updates from the AcreetionOS operating system project. Maintained by Natalie.">
  <h1>AcreetionOS Blog</h1>
  <p style="margin-bottom: 2.5rem; font-size: 1.05rem;">
    Updates, development progress, and community news from the AcreetionOS project.
    <br/><a href="/rss.xml">Subscribe via RSS</a>
  </p>

  {posts.length === 0 && (
    <p style="text-align: center; padding: 3rem 0; color: var(--muted);">
      No posts yet. Coming soon.
    </p>
  )}

  <ul class="card-list">
    {posts.map((post) => (
      <li class="card">
        <a href={`/posts/${post.id}`} class="card-title">
          {post.data.title}
        </a>
        <div class="meta" style="margin-top: 0.4rem;">
          {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          {post.data.tags?.map(tag => <span class="tag">{tag}</span>)}
        </div>
        <p style="margin: 0.3rem 0 0; font-size: 0.9rem;">
          {post.data.description}
        </p>
      </li>
    ))}
  </ul>
</BaseLayout>
